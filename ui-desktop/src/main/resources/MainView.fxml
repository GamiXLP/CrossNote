<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import java.lang.String?>
<BorderPane
        styleClass="root"
        stylesheets="@styles.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="crossnote.desktop.MainController">

    <!-- ================= TOP BAR ================= -->
    <top>
        <HBox spacing="14" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>

            <!-- App Icon -->
            <StackPane styleClass="app-icon">
                <SVGPath styleClass="icon-large"
                         content="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
            </StackPane>

            <Label text="CrossNote" styleClass="app-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Theme Toggle -->
            <Button fx:id="BTNdarkmode"
                    onAction="#darkmode_on"
                    mnemonicParsing="false">
                <styleClass>
                    <String fx:value="icon-button"/>
                    <String fx:value="theme-toggle"/>
                </styleClass>

                <graphic>
                    <StackPane>

                        <!-- Lightmode aktiv -> Mond anzeigen (Stroke) -->
                        <SVGPath content="M20.539 14.852A8 8 0 0 1 11 7c0-1.457.32-2.823 1-4a9 9 0 1 0 8.539 11.852ZM16.625 4l.044.08l.081.045l-.08.044l-.045.081l-.044-.08l-.081-.045l.08-.044zM20.5 8.5l.177.323L21 9l-.323.177l-.177.323l-.177-.323L20 9l.323-.177z">
                            <styleClass>
                                <String fx:value="icon"/>
                                <String fx:value="theme-icon-light"/>
                            </styleClass>
                        </SVGPath>

                        <!-- Darkmode aktiv -> Sonne anzeigen (Fill) -->
                        <SVGPath content="M12 9c1.65 0 3 1.35 3 3s-1.35 3-3 3s-3-1.35-3-3s1.35-3 3-3m0-2c-2.76 0-5 2.24-5 5s2.24 5 5 5s5-2.24 5-5s-2.24-5-5-5M2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1m18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1M11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1m0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1M5.99 4.58a.996.996 0 0 0-1.41 0a.996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41zm12.37 12.37a.996.996 0 0 0-1.41 0a.996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 0 0 0-1.41zm1.06-10.96a.996.996 0 0 0 0-1.41a.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0zM7.05 18.36a.996.996 0 0 0 0-1.41a.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0z">
                            <styleClass>
                                <String fx:value="icon-filled"/>
                                <String fx:value="theme-icon-dark"/>
                            </styleClass>
                        </SVGPath>

                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </top>

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox minWidth="400" spacing="12" styleClass="sidebar">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>

            <StackPane VBox.vgrow="ALWAYS" styleClass="card sidebar-card">

                <!-- NOTEBOOKS -->
                <AnchorPane fx:id="APnotebooks">
                    <children>
                        <VBox spacing="12"
                              AnchorPane.topAnchor="0"
                              AnchorPane.bottomAnchor="0"
                              AnchorPane.leftAnchor="0"
                              AnchorPane.rightAnchor="0">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <SVGPath styleClass="icon"
                                         content="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                                <Label text="Notizen" styleClass="section-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <TextField fx:id="TFnotebook"
                                       promptText="Suchen…"
                                       styleClass="search-field"/>

                            <TreeView fx:id="TVnotebook"
                                      styleClass="sidebar-list"
                                      VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </children>
                </AnchorPane>

                <!-- TRASH -->
                <AnchorPane fx:id="APtrashcan" visible="false">
                    <children>
                        <VBox spacing="12"
                              AnchorPane.topAnchor="0"
                              AnchorPane.bottomAnchor="0"
                              AnchorPane.leftAnchor="0"
                              AnchorPane.rightAnchor="0">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <SVGPath styleClass="icon"
                                         content="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                                <Label text="Papierkorb" styleClass="section-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <TextField fx:id="TFtrashcan"
                                       promptText="Suchen…"
                                       styleClass="search-field"/>

                            <TreeView fx:id="TVtrashcan"
                                      styleClass="sidebar-list"
                                      VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </children>
                </AnchorPane>

                <!-- SAVESTATE -->
                <AnchorPane fx:id="APsavestate" visible="false">
                    <children>
                        <VBox spacing="12"
                              AnchorPane.topAnchor="0"
                              AnchorPane.bottomAnchor="0"
                              AnchorPane.leftAnchor="0"
                              AnchorPane.rightAnchor="0">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <SVGPath styleClass="icon"
                                         content="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                                <Label text="Speicherstände" styleClass="section-title"/>
                                <Label fx:id="LBdataname"
                                       text="Dateiname"
                                       styleClass="section-title"
                                       HBox.hgrow="ALWAYS"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="BTNload"
                                        styleClass="icon-pill"
                                        mnemonicParsing="false">
                                    <graphic>
                                        <SVGPath styleClass="icon"
                                                 content="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                                    </graphic>
                                </Button>
                            </HBox>

                            <ListView fx:id="LVsavestate"
                                      styleClass="sidebar-list"
                                      VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </children>
                </AnchorPane>

            </StackPane>

            <Separator/>

            <!-- Bottom Buttons -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="BTNtrashcan"
                        styleClass="icon-pill"
                        mnemonicParsing="false">
                    <graphic>
                        <SVGPath styleClass="icon"
                                 content="
                                   M12 20h5c0.5 0 1 -0.5 1 -1v-14
                                   M12 20h-5c-0.5 0 -1 -0.5 -1 -1v-14
                                   M4 5h16
                                   M10 4h4
                                   M10 9v7
                                   M14 9v7
                                 "/>
                    </graphic>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="BTNsavestate"
                        visible="false"
                        managed="false"
                        styleClass="icon-pill"
                        mnemonicParsing="false">
                    <graphic>
                        <SVGPath styleClass="icon"
                                 content="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                    </graphic>
                </Button>
            </HBox>

        </VBox>
    </left>

    <!-- ================= CENTER EDITOR ================= -->
    <center>
        <VBox spacing="10" styleClass="note-list-container">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="titleField"
                           promptText="Titel der Notiz"
                           styleClass="note-title"
                           HBox.hgrow="ALWAYS"/>

                <Button fx:id="BTNsave"
                        styleClass="icon-pill primary"
                        mnemonicParsing="false">
                    <graphic>
                        <SVGPath styleClass="icon"
                                 content="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                    </graphic>
                </Button>
            </HBox>

            <TextArea fx:id="contentArea"
                      promptText="Schreibe deine Notiz hier…"
                      styleClass="note-content"
                      VBox.vgrow="ALWAYS"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Zuletzt geändert:"/>
                <Label fx:id="LBlastchange" text="--"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="LBsaved"
                       text="Nicht gespeichert"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
