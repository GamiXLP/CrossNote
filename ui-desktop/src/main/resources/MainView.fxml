<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane styleClass="root" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="crossnote.desktop.MainController">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="12" styleClass="top-bar">
            <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true" HBox.hgrow="ALWAYS">
                <image>
                    <Image url="@images/CrossNote_Icon.png" />
                </image>
            </ImageView>

            <Label styleClass="app-title" text="CrossNote" HBox.hgrow="ALWAYS" />
            <Region HBox.hgrow="ALWAYS" />

            <!-- Darkmode Button: nur Icon (Graphic wird im Controller gesetzt) -->
            <Button fx:id="BTNdarkmode"
                    onAction="#darkmode_on"
                    text=""
                    contentDisplay="GRAPHIC_ONLY"
                    styleClass="icon-button"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox minWidth="400.0" spacing="10" styleClass="sidebar">
            <StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
                <children>
                    <AnchorPane fx:id="APnotebooks" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
                        <children>
                            <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                <children>
                                    <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                           styleClass="section-title" text="📔 Notizbücher/Notizen" VBox.vgrow="NEVER" />
                                    <TextField fx:id="TFnotebook" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                               promptText="Suchen…" styleClass="search-field" VBox.vgrow="NEVER" />
                                    <ListView fx:id="LVnotebook" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                              minHeight="0.0" styleClass="sidebar-list" VBox.vgrow="ALWAYS" />
                                </children>
                            </VBox>
                        </children>
                    </AnchorPane>

                    <AnchorPane fx:id="APtrashcan" visible="false">
                        <children>
                            <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                <children>
                                    <HBox>
                                        <children>
                                            <Label styleClass="section-title" text="🗑 Papierkorb" />
                                            <Region HBox.hgrow="ALWAYS" />

                                            <Button fx:id="BTNrestore"
                                                    contentDisplay="GRAPHIC_ONLY"
                                                    graphicTextGap="6"
                                                    mnemonicParsing="false"
                                                    styleClass="icon-button">
                                                <graphic>
                                                    <Group>
                                                        <SVGPath content="m19.5 5.5l-.5 6m-14.5-6l.605 10.037c.154 2.57.232 3.855.874 4.78a4 4 0 0 0 1.2 1.132c.582.356 1.284.496 2.321.551"
                                                                 fill="transparent" stroke="black" strokeLineCap="ROUND" strokeWidth="1.5" />
                                                        <SVGPath content="m11 15.5l1.136 1.466a4 4 0 0 1 7.364-.901M21 20.5l-1.136-1.464a4 4 0 0 1-7.328.965"
                                                                 fill="transparent" stroke="black" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                                                        <SVGPath content="M3 5.5h18m-4.944 0l-.683-1.408c-.453-.936-.68-1.403-1.071-1.695a2 2 0 0 0-.275-.172C13.594 2 13.074 2 12.035 2c-1.066 0-1.599 0-2.04.234a2 2 0 0 0-.278.18c-.395.303-.616.788-1.058 1.757L8.053 5.5"
                                                                 fill="transparent" stroke="black" strokeLineCap="ROUND" strokeWidth="1.5" />
                                                    </Group>
                                                </graphic>
                                            </Button>
                                        </children>
                                    </HBox>

                                    <TextField fx:id="TFtrashcan" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                               promptText="Suchen…" styleClass="search-field" VBox.vgrow="NEVER" />
                                    <ListView fx:id="LVtrashcan" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                              minHeight="0.0" styleClass="sidebar-list" VBox.vgrow="ALWAYS" />
                                </children>
                            </VBox>
                        </children>
                    </AnchorPane>

                    <AnchorPane fx:id="APsavestate" visible="false">
                        <children>
                            <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                <children>
                                    <HBox VBox.vgrow="NEVER">
                                        <children>
                                            <Label styleClass="section-title" text="📋 Speicherstände: " />
                                            <Label fx:id="LBdataname" styleClass="section-title" text="Dateiname" HBox.hgrow="ALWAYS" />
                                            <Region HBox.hgrow="ALWAYS" />

                                            <Button fx:id="BTNload"
                                                    contentDisplay="GRAPHIC_ONLY"
                                                    graphicTextGap="6"
                                                    mnemonicParsing="false"
                                                    styleClass="icon-button">
                                                <graphic>
                                                    <Group>
                                                        <SVGPath content="M19.933 13.041a8 8 0 1 1-9.925-8.788c3.899-1 7.935 1.007 9.425 4.747"
                                                                 fill="transparent" stroke="black" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2" />
                                                        <SVGPath content="M20 4v5h-5"
                                                                 fill="transparent" stroke="black" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2" />
                                                    </Group>
                                                </graphic>
                                            </Button>
                                        </children>
                                    </HBox>

                                    <ListView fx:id="LVsavestate" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                              styleClass="sidebar-list" VBox.vgrow="ALWAYS" />
                                </children>
                            </VBox>
                        </children>
                    </AnchorPane>
                </children>
            </StackPane>

            <Separator />

            <HBox alignment="CENTER">
                <children>
                    <Button fx:id="BTNtrashcan"
                            contentDisplay="GRAPHIC_ONLY"
                            graphicTextGap="6"
                            styleClass="icon-button">
                        <graphic>
                            <Group scaleX="1.0" scaleY="1.0">
                                <SVGPath content="M12 20h5c0.5 0 1 -0.5 1 -1v-14M12 20h-5c-0.5 0 -1 -0.5 -1 -1v-14"
                                         fill="transparent" stroke="black" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2" />
                                <SVGPath content="M4 5h16"
                                         fill="transparent" stroke="black" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2" />
                                <SVGPath content="M10 4h4M10 9v7M14 9v7"
                                         fill="transparent" stroke="black" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2" />
                            </Group>
                        </graphic>
                    </Button>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="BTNsavestate"
                            contentDisplay="GRAPHIC_ONLY"
                            graphicTextGap="6"
                            styleClass="icon-button">
                        <graphic>
                            <Group>
                                <SVGPath content="M8.586 1c.395 0 .782.16 1.061.44l2.913 2.912c.279.28.439.666.439 1.061V13c0 1.103-.897 2-2 2h-7c-1.103 0-2-.897-2-2V5h1v7.999a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V5.412a.5.5 0 0 0-.147-.354L8.94 2.144a.5.5 0 0 0-.354-.146h-.677c-.009-.026-.013-.051-.023-.077a1.5 1.5 0 0 0-.324-.482L7.122 1z"
                                         fill="black" />
                                <SVGPath content="M9.5 10.999a.5.5 0 0 1 0 1h-4a.5.5 0 0 1 0-1zm-2-7a.5.5 0 0 1 .5.5v1.5h1.5a.5.5 0 0 1 0 1H8v1.5a.5.5 0 0 1-1 0v-1.5H5.5a.5.5 0 0 1 0-1H7v-1.5a.5.5 0 0 1 .5-.5M4.5 0a.5.5 0 0 1 .354.147l2 2A.48.48 0 0 1 7 2.501a.5.5 0 0 1-.147.354l-2 2a.5.5 0 1 1-.708-.708l1.147-1.146H2.5a1.5 1.5 0 0 0-1.5 1.5v1a.501.501 0 1 1-1 0v-1a2.5 2.5 0 0 1 2.5-2.5h2.793L4.146.855A.502.502 0 0 1 4.5 0"
                                         fill="black" />
                            </Group>
                        </graphic>
                    </Button>
                </children>
            </HBox>
        </VBox>
    </left>

    <!-- CENTER -->
    <center>
        <VBox spacing="8.0" styleClass="note-list-container">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="titleField" promptText="Titel der Notiz" styleClass="note-title" HBox.hgrow="ALWAYS" />

                        <Button fx:id="BTNsave"
                                contentDisplay="GRAPHIC_ONLY"
                                graphicTextGap="6"
                                styleClass="icon-button" HBox.hgrow="NEVER">
                            <graphic>
                                <SVGPath content="M20 7.423v10.962q0 .69-.462 1.153T18.384 20H5.616q-.691 0-1.153-.462T4 18.384V5.616q0-.691.463-1.153T5.616 4h10.961zm-1 .427L16.15 5H5.616q-.27 0-.443.173T5 5.616v12.769q0 .269.173.442t.443.173h12.769q.269 0 .442-.173t.173-.443zm-7 8.688q.827 0 1.414-.586T14 14.538t-.587-1.413T12 12.539t-1.413.586T10 14.538t.587 1.414t1.413.586M6.77 9.77h7.422v-3H6.77zM5 7.85V19V5z"
                                         fill="black" />
                            </graphic>
                        </Button>

                        <Button fx:id="BTNdelete"
                                contentDisplay="GRAPHIC_ONLY"
                                graphicTextGap="6"
                                mnemonicParsing="false"
                                styleClass="icon-button">
                            <graphic>
                                <SVGPath content="M3 8v8h2a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2zm11 0h-4v8h4m-4-4h2.5M17 8v8h4"
                                         fill="transparent" stroke="black" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2" />
                            </graphic>
                        </Button>

                        <Button fx:id="BTNnewnote"
                                contentDisplay="GRAPHIC_ONLY"
                                graphicTextGap="6"
                                styleClass="icon-button" HBox.hgrow="NEVER">
                            <graphic>
                                <SVGPath content="M2 1.625A.375.375 0 0 0 1.625 2v10a.375.375 0 0 0 .375.375h5.875V9A1.125 1.125 0 0 1 9 7.875h3.375V2A.375.375 0 0 0 12 1.625zm11.451 7.307a.62.62 0 0 0 .174-.432V2A1.625 1.625 0 0 0 12 .375H2A1.625 1.625 0 0 0 .375 2v10A1.625 1.625 0 0 0 2 13.625h6.5a.62.62 0 0 0 .442-.183l4.5-4.5z"
                                         fill="black" fillRule="EVEN_ODD" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>

                <TextArea fx:id="contentArea" promptText="Schreibe deine Notiz hier…" styleClass="note-content" VBox.vgrow="ALWAYS" />

                <HBox spacing="10">
                    <Label text="Zuletzt geändert: " HBox.hgrow="NEVER" />
                    <Label fx:id="LBlastchange" text="--" HBox.hgrow="ALWAYS" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="LBsaved" prefWidth="160.0" text="Nicht gespeichert" HBox.hgrow="NEVER" />
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>