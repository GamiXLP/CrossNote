@startuml
title CrossNote – High-Level Overview
left to right direction
skinparam shadowing false
skinparam linetype ortho
skinparam rectangle {
  StereotypeFontSize 12
}

rectangle "UI (Boundary)\nNotizGUI • LoginForm • SyncView" as UI
rectangle "Application (Control)\nNotizVerwaltung • BenutzerVerwaltung • SyncController" as APP
rectangle "Domain (Entities)\nBenutzer • Notiz • Kategorie • Anhang • Geraet" as DOMAIN
rectangle "Infrastructure (Persistence/Services)\nRepos • LocalDb • Auth/SyncService • CloudApiClient" as INFRA

UI --> APP
APP --> DOMAIN
APP --> INFRA
INFRA ..> DOMAIN : DTO/Entity Mappings

@enduml
